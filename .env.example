# Client-side Google Maps Platform key, used by the Maps JavaScript API (interactive map,
# satellite toggle, Street View panorama) in the Present-Day View panel.
# Restrict this key in Google Cloud Console (APIs & Services > Credentials) to:
#   - Application restriction: HTTP referrers -> http://localhost:3000/* (add your real domain
#     once deployed)
#   - API restriction: Maps JavaScript API only
# This key is visible in the browser by design (that's how Maps JS API works everywhere) —
# the referrer restriction is its real protection. Never put the server key here.
REACT_APP_GOOGLE_MAPS_API_KEY=your_client_key_here

# Optional: override the backend API base URL. Leave empty in local dev — the React dev
# server proxies /api to Express on port 3001 (see src/setupProxy.js). Run the API with
# `cd server && npm run dev`; keep the React app on port 3000 only (do not start React on 3001).
REACT_APP_API_URL=
