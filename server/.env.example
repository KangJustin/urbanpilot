ANTHROPIC_API_KEY=your_key_here
PORT=3001

# Optional: port for the one-time Midjourney OAuth callback used by the
# "Generate with Midjourney" button. The backend connects directly to
# https://mcp.midjourney.com/mcp; the first generation request opens a
# browser for you to authorize with your Midjourney account (use the Mega
# plan account), then caches tokens in server/.mcp-auth/midjourney.json.
MIDJOURNEY_OAUTH_PORT=8090
