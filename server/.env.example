ANTHROPIC_API_KEY=your_key_here
PORT=3001

# Optional: port for the one-time Midjourney OAuth callback used by the
# "Generate with Midjourney" button. The backend connects directly to
# https://mcp.midjourney.com/mcp; the first generation request opens a
# browser for you to authorize with your Midjourney account (use the Mega
# plan account), then caches tokens in server/.mcp-auth/midjourney.json.
MIDJOURNEY_OAUTH_PORT=8090

# Server-side Google Maps Platform key. Powers location search (Places API (New) Autocomplete +
# Place Details), the Street View coverage check, and the Street View/satellite image proxies.
# Restrict this key in Google Cloud Console (APIs & Services > Credentials) by API only:
# Places API (New), Geocoding API, Street View Static API, Maps Static API. Do NOT add
# Maps JavaScript API to this key, and never expose it to the frontend — that's a separate,
# referrer-restricted key (see REACT_APP_GOOGLE_MAPS_API_KEY in the root .env.example).
GOOGLE_MAPS_SERVER_API_KEY=your_server_key_here

# U.S. Census Bureau API key for ACS housing/demographic data in the Housing Agent.
# https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_key_here

# Optional: comma-separated list of additional CORS origins, e.g. for LAN sharing.
ALLOWED_ORIGINS=
